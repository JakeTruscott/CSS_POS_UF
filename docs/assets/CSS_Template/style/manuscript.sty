
% -----------------------
% Basic packages
% -----------------------
\usepackage{lipsum}
\usepackage{amsmath, amssymb, amsfonts}   % math
\usepackage{graphicx}                     % figures
\usepackage{geometry}                     % page layout
\usepackage{setspace}                     % spacing
\usepackage{caption}                      % caption control
\usepackage{subfig}                    % subfigures
\usepackage{color,xcolor}                 % colors
\usepackage{array}                        % table columns
\usepackage{multirow}                     % multirow tables
\usepackage{booktabs}                     % nicer tables
\usepackage{float}                        % float placement
\usepackage{pdflscape}                    % landscape pages
\usepackage{longtable}                     % long tables
\usepackage{adjustbox}                     % adjustbox for tables/figures
\usepackage{authblk}                       % author affiliations
\usepackage{natbib}                        % bibliography\
\usepackage{makecell}
\usepackage{rotating}
\usepackage{color, xcolor, soul}
\usepackage{circuitikz, tikz, comment}
% -----------------------
% Page geometry
% -----------------------
\geometry{left=1in,right=1in,top=1in,bottom=1in}

% -----------------------
% Spacing
% -----------------------
\doublespacing

% -----------------------
% Theorem environments
% -----------------------
\newtheorem{theorem}{Theorem}
\newtheorem{proposition}{Proposition}
\newtheorem{corollary}[theorem]{Corollary}
\newtheorem{hyp}{Hypothesis}
\newtheorem{subhyp}{Hypothesis}[hyp]
\renewcommand{\thesubhyp}{\thehyp\alph{subhyp}}

% -----------------------
% Proof environment
% -----------------------
\newenvironment{proof}[1][Proof]{\noindent\textbf{#1.} }{\ \rule{0.5em}{0.5em}}

% -----------------------
% Custom commands
% -----------------------
\newcommand{\red}[1]{{\color{red} #1}}
\newcommand{\blue}[1]{{\color{blue} #1}}

\usepackage{footmisc}
%\renewcommand{\footnotelayout}{\setstretch{2}}


% Column types for tables
\newcolumntype{L}[1]{>{\raggedright\arraybackslash}m{#1}}
\newcolumntype{C}[1]{>{\centering\arraybackslash}m{#1}}
\newcolumntype{R}[1]{>{\raggedleft\arraybackslash}m{#1}}

% -----------------------
% Float control
% -----------------------
\renewcommand{\topfraction}{0.9}
\renewcommand{\textfraction}{0.05}
\renewcommand{\floatpagefraction}{0.8}
\setcounter{topnumber}{5}
\setcounter{totalnumber}{10}

% -----------------------
% Hyperref (if desired)
% -----------------------
\usepackage{hyperref}
\hypersetup{
    colorlinks=true,
    linkcolor=blue,
    citecolor=blue,
    urlcolor=blue
}

