ag$title_clean <- sapply(ag$title, reduce_complexity(x))
ag$title_clean <- sapply(ag$title, reduce_complexity() function(x))
ag$title_clean <- sapply(ag$title, function(x) reduce_complexity(x))
ag$title_clean <- reduce_complexity(ag$title)
